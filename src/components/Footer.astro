---
const year = new Date().getFullYear()
---

<footer class="border-t border-border">
  <div class="max-w-6xl mx-auto px-6 py-16">
    <div class="grid md:grid-cols-3 gap-12 mb-16">
      <!-- Brand -->
      <div>
        <div class="flex items-center gap-3 mb-4">
          <div class="relative">
            <!-- Lucide: mountain -->
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#4ADE80" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="m8 3 4 8 5-5 5 15H2L8 3z"/>
            </svg>
          </div>
          <span class="font-bold text-text">YahoLink</span>
          <span class="font-serif text-xs text-muted border border-border px-1.5 py-0.5 rounded">野歩</span>
        </div>
        <p class="text-sm text-muted leading-relaxed max-w-xs">
          Restez connecté à chaque pas. Un pont entre la nature et vos proches.
        </p>
        <a
          href="https://yahoki.fr"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 mt-4 text-xs text-muted hover:text-green transition-colors"
        >
          Un projet de yahoki.fr
          <svg width="12" height="12" viewBox="0 0 16 16" fill="none">
            <path d="M3 13L13 3M13 3H7M13 3v6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
          </svg>
        </a>
      </div>

      <!-- Links -->
      <div>
        <h4 class="text-xs font-mono text-muted tracking-widest uppercase mb-5">Ressources</h4>
        <ul class="space-y-3">
          <li>
            <a
              href="https://github.com/juliensyx/hikingtrack"
              target="_blank"
              rel="noopener noreferrer"
              class="text-sm text-muted hover:text-text transition-colors flex items-center gap-2"
            >
              <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
                <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/>
              </svg>
              GitHub
            </a>
          </li>
          <li>
            <a
              href="https://app.yaholink.fr"
              target="_blank"
              rel="noopener noreferrer"
              class="text-sm text-muted hover:text-text transition-colors"
            >
              Application
            </a>
          </li>
          <li>
            <a
              href="https://app.yaholink.fr/beta"
              target="_blank"
              rel="noopener noreferrer"
              class="text-sm text-muted hover:text-text transition-colors"
            >
              Rejoindre la bêta
            </a>
          </li>
        </ul>
      </div>

      <!-- Legal / Contact -->
      <div>
        <h4 class="text-xs font-mono text-muted tracking-widest uppercase mb-5">Légal</h4>
        <ul class="space-y-3">
          <li>
            <a
              href="https://app.yaholink.fr/privacy"
              target="_blank"
              rel="noopener noreferrer"
              class="text-sm text-muted hover:text-text transition-colors"
            >
              Politique de confidentialité
            </a>
          </li>
          <li>
            <a
              href="https://yahoki.fr/contact"
              target="_blank"
              rel="noopener noreferrer"
              class="text-sm text-muted hover:text-text transition-colors"
            >
              Signaler un bug
            </a>
          </li>
        </ul>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="border-t border-border pt-8 flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-xs text-muted font-mono">
        © {year} YahoLink · Développé avec passion par{' '}
        <a
          href="https://yahoki.fr"
          target="_blank"
          rel="noopener noreferrer"
          class="text-green hover:underline"
        >Julien Syx</a>
      </p>
      <div class="flex items-center gap-3 text-xs text-muted/40 font-mono">
        <span>野</span>
        <span class="w-4 h-px bg-border"></span>
        <span>歩</span>
        <span class="w-4 h-px bg-border"></span>
        <span>Link</span>
      </div>
    </div>
  </div>
</footer>
