---
const steps = [
  {
    number: '01',
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
      <rect x="5" y="2" width="14" height="20" rx="2"/>
      <circle cx="12" cy="17" r="1" fill="currentColor"/>
      <path d="M9 6h6"/>
    </svg>`,
    title: 'Application Android',
    description: 'Installez l\'app YahoLink Android sur votre téléphone. Créez votre compte et générez une clé API dans votre profil.',
  },
  {
    number: '02',
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
      <path d="M3 12h18M12 3l9 9-9 9"/>
    </svg>`,
    title: 'Sync automatique',
    description: 'Pendant votre randonnée, l\'app envoie votre position GPS toutes les quelques minutes via POST /api/sync.',
  },
  {
    number: '03',
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
      <circle cx="12" cy="12" r="3"/>
      <path d="M12 2v3M12 19v3M2 12h3M19 12h3"/>
      <path d="M5.6 5.6l2.1 2.1M16.3 16.3l2.1 2.1M5.6 18.4l2.1-2.1M16.3 7.7l2.1-2.1"/>
    </svg>`,
    title: 'Carte en direct',
    description: 'La carte se met à jour en temps réel avec votre position, votre trace GPX, l\'altitude et votre progression.',
  },
  {
    number: '04',
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
      <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
      <circle cx="9" cy="7" r="4"/>
      <path d="M23 21v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75"/>
    </svg>`,
    title: 'Vos proches suivent',
    description: 'Envoyez le lien de partage à votre famille. Sans compte, ils suivent votre aventure et peuvent vous envoyer des encouragements.',
  },
]
---

<section class="py-24 relative" id="how-it-works">
  <!-- Separator line -->
  <div class="max-w-6xl mx-auto px-6">
    <div class="border-t border-border mb-20"></div>
  </div>

  <div class="max-w-6xl mx-auto px-6">
    <!-- Header -->
    <p class="reveal text-xs font-mono text-green tracking-[0.3em] uppercase mb-4">Comment ça marche</p>
    <h2 class="reveal delay-100 text-4xl md:text-5xl font-bold tracking-tight mb-16">
      En marche en<br class="hidden md:block" /> 4 étapes.
    </h2>

    <!-- Steps grid -->
    <div class="grid md:grid-cols-4 gap-px bg-border rounded-2xl overflow-hidden">
      {steps.map((step, i) => (
        <div class={`reveal delay-${(i + 1) * 100} bg-surface p-8 relative group hover:bg-surface/70 transition-colors`}>
          <!-- Step number -->
          <div class="text-xs font-mono text-green/40 tracking-widest mb-6">{step.number}</div>

          <!-- Icon -->
          <div class="w-12 h-12 rounded-xl bg-green/10 border border-green/20 flex items-center justify-center text-green mb-6 group-hover:bg-green/15 transition-colors" set:html={step.icon} />

          <!-- Content -->
          <h3 class="text-base font-semibold text-text mb-3">{step.title}</h3>
          <p class="text-sm text-muted leading-relaxed">{step.description}</p>

          <!-- Arrow connector (not on last) -->
          {i < steps.length - 1 && (
            <div class="hidden md:block absolute -right-3 top-1/2 -translate-y-1/2 z-10">
              <div class="w-6 h-6 rounded-full bg-border border border-border flex items-center justify-center">
                <svg width="10" height="10" viewBox="0 0 10 10" fill="none">
                  <path d="M2 5h6M6 3l2 2-2 2" stroke="#6B7A6E" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </div>
            </div>
          )}
        </div>
      ))}
    </div>

    <!-- API detail -->
    <div class="reveal delay-400 mt-8 bg-surface border border-border rounded-xl p-6 flex flex-col sm:flex-row items-start sm:items-center gap-4">
      <div class="flex-shrink-0 w-10 h-10 rounded-lg bg-green/10 border border-green/20 flex items-center justify-center">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#4ADE80" stroke-width="1.5" stroke-linecap="round">
          <path d="M7 8l-4 4 4 4M17 8l4 4-4 4M14 4l-4 16"/>
        </svg>
      </div>
      <div class="flex-1">
        <div class="text-sm font-semibold text-text mb-1">API ouverte et documentée</div>
        <p class="text-xs text-muted">
          Tout appareil capable de faire un HTTP POST peut envoyer des positions. Pas de SDK propriétaire.
        </p>
      </div>
      <div class="font-mono text-xs bg-bg border border-border rounded-lg px-4 py-2.5 text-green whitespace-nowrap">
        POST /api/sync
      </div>
    </div>
  </div>
</section>
