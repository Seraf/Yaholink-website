---
---

<section class="py-32 relative overflow-hidden" id="beta">
  <!-- Background glow -->
  <div class="absolute inset-0 pointer-events-none">
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[400px] rounded-full"
      style="background: radial-gradient(ellipse, rgba(74,222,128,0.06) 0%, transparent 70%);">
    </div>
  </div>

  <div class="relative z-10 max-w-2xl mx-auto px-6 text-center">
    <!-- Label -->
    <p class="reveal text-xs font-mono text-green tracking-[0.3em] uppercase mb-6">Bêta privée</p>

    <!-- Headline -->
    <h2 class="reveal delay-100 text-4xl md:text-5xl font-bold tracking-tight mb-6">
      Rejoignez les premiers<br />
      <span class="text-gradient">explorateurs.</span>
    </h2>

    <p class="reveal delay-200 text-muted text-lg mb-10 leading-relaxed">
      YahoLink est en bêta privée. Laissez votre adresse email et
      vous serez parmi les premiers à découvrir l'application.
    </p>

    <!-- Form -->
    <form
      id="beta-form"
      class="reveal delay-300 flex flex-col sm:flex-row gap-3 max-w-md mx-auto"
    >
      <input
        type="email"
        name="email"
        id="beta-email"
        required
        placeholder="votre@email.com"
        class="flex-1 bg-surface border border-border text-text placeholder:text-muted rounded-xl px-4 py-3 text-sm focus:outline-none focus:border-green/50 focus:ring-1 focus:ring-green/30 transition-all"
      />
      <button
        type="submit"
        id="beta-submit"
        class="bg-green text-bg font-semibold px-6 py-3 rounded-xl text-sm hover:bg-green/90 transition-all hover:shadow-lg hover:shadow-green/20 whitespace-nowrap disabled:opacity-50 disabled:cursor-not-allowed"
      >
        Rejoindre
      </button>
    </form>

    <!-- Success state (hidden by default) -->
    <div id="beta-success" class="hidden mt-6 flex-col items-center gap-3">
      <div class="w-12 h-12 rounded-full bg-green/20 border border-green/40 flex items-center justify-center mx-auto">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#4ADE80" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="20 6 9 17 4 12"/>
        </svg>
      </div>
      <p class="text-text font-semibold">Vous êtes sur la liste !</p>
      <p class="text-sm text-muted">On vous contactera dès que la bêta est disponible.</p>
    </div>

    <!-- Error state (hidden by default) -->
    <div id="beta-error" class="hidden mt-4 text-sm text-red-400 font-mono"></div>

    <!-- Social proof -->
    <p class="reveal delay-400 text-xs text-muted mt-8">
      Pas de spam. Pas d'engagement. Juste une notification quand c'est prêt.
    </p>
  </div>
</section>

<script>
  const form = document.getElementById('beta-form') as HTMLFormElement | null
  const emailInput = document.getElementById('beta-email') as HTMLInputElement | null
  const submitBtn = document.getElementById('beta-submit') as HTMLButtonElement | null
  const successDiv = document.getElementById('beta-success')
  const errorDiv = document.getElementById('beta-error')

  form?.addEventListener('submit', async (e) => {
    e.preventDefault()
    if (!emailInput || !submitBtn) return

    const email = emailInput.value.trim()
    submitBtn.disabled = true
    submitBtn.textContent = 'Envoi…'

    try {
      const res = await fetch('https://app.yaholink.fr/beta', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email }),
      })

      if (res.ok || res.status === 201 || res.status === 200) {
        form.style.display = 'none'
        successDiv?.classList.remove('hidden')
        successDiv?.classList.add('flex')
      } else {
        const data = await res.json().catch(() => ({}))
        if (errorDiv) {
          errorDiv.textContent = (data as { message?: string }).message ?? 'Une erreur est survenue. Réessayez.'
          errorDiv.classList.remove('hidden')
        }
        submitBtn.disabled = false
        submitBtn.textContent = 'Rejoindre'
      }
    } catch {
      if (errorDiv) {
        errorDiv.textContent = 'Impossible de joindre le serveur. Réessayez plus tard.'
        errorDiv.classList.remove('hidden')
      }
      submitBtn.disabled = false
      submitBtn.textContent = 'Rejoindre'
    }
  })
</script>
