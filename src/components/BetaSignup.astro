---
---

<section class="py-32 relative overflow-hidden" id="beta">
  <!-- Background glow -->
  <div class="absolute inset-0 pointer-events-none">
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[400px] rounded-full"
      style="background: radial-gradient(ellipse, rgba(74,222,128,0.06) 0%, transparent 70%);">
    </div>
  </div>

  <div class="relative z-10 max-w-2xl mx-auto px-6 text-center">
    <!-- Label -->
    <p class="reveal text-xs font-mono text-green tracking-[0.3em] uppercase mb-6">Bêta privée</p>

    <!-- Headline -->
    <h2 class="reveal delay-100 text-4xl md:text-5xl font-bold tracking-tight mb-6">
      Rejoignez les premiers<br />
      <span class="text-gradient">explorateurs.</span>
    </h2>

    <p class="reveal delay-200 text-muted text-lg mb-10 leading-relaxed">
      YahoLink est en bêta privée. Créez votre compte et
      soyez parmi les premiers à découvrir l'application.
    </p>

    <!-- CTA -->
    <div class="reveal delay-300">
      <a
        href="https://app.yaholink.fr/beta"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-3 bg-green text-bg font-semibold px-8 py-4 rounded-xl text-base hover:bg-green/90 transition-all hover:shadow-xl hover:shadow-green/20 hover:-translate-y-0.5"
      >
        <!-- Lucide: mountain -->
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="m8 3 4 8 5-5 5 15H2L8 3z"/>
        </svg>
        Rejoindre la bêta
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
          <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
    </div>

    <p class="reveal delay-400 text-xs text-muted mt-8">
      Pas de spam. Pas d'engagement. Juste une notification quand c'est prêt.
    </p>
  </div>
</section>
