---
---

<section class="relative min-h-screen flex flex-col items-center justify-center overflow-hidden pt-20">
  <!-- Grid background -->
  <div class="absolute inset-0 grid-bg opacity-40 pointer-events-none"></div>

  <!-- Radial green glow from center -->
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[800px] rounded-full pointer-events-none"
    style="background: radial-gradient(circle, rgba(74,222,128,0.07) 0%, transparent 70%);">
  </div>

  <!-- Animated elevation SVG in background -->
  <div class="absolute bottom-0 left-0 right-0 pointer-events-none opacity-10">
    <svg viewBox="0 0 1440 200" fill="none" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none">
      <path
        d="M0,160 C60,160 80,120 120,110 C160,100 180,130 240,100 C300,70 320,40 380,30 C440,20 460,60 520,80 C580,100 600,60 660,40 C720,20 740,70 800,90 C860,110 880,80 940,70 C1000,60 1020,100 1080,110 C1140,120 1160,90 1220,100 C1280,110 1360,130 1440,120 L1440,200 L0,200 Z"
        fill="#4ADE80"
        class="elevation-path"
      />
    </svg>
  </div>

  <div class="relative z-10 max-w-6xl mx-auto px-6 text-center">
    <!-- Label -->
    <div class="reveal inline-flex items-center gap-2 border border-green/30 bg-green/5 text-green text-xs font-mono px-3 py-1.5 rounded-full mb-8 tracking-wider">
      <span class="w-1.5 h-1.5 bg-green rounded-full animate-pulse"></span>
      Bêta privée — Rejoignez la liste
    </div>

    <!-- Headline -->
    <h1 class="reveal delay-100 text-5xl md:text-7xl font-extrabold leading-tight tracking-tight mb-6">
      Restez connecté<br />
      <span class="text-gradient">à chaque pas.</span>
    </h1>

    <!-- Sub-headline -->
    <p class="reveal delay-200 text-lg md:text-xl text-muted max-w-2xl mx-auto mb-10 leading-relaxed">
      YahoLink suit votre position GPS en temps réel pendant vos randonnées
      et la partage avec vos proches — sans compte, sans friction.
    </p>

    <!-- CTAs -->
    <div class="reveal delay-300 flex flex-col sm:flex-row items-center justify-center gap-4 mb-16">
      <a
        href="https://app.yaholink.fr/beta"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 bg-green text-bg font-semibold px-6 py-3 rounded-xl text-sm hover:bg-green/90 transition-all hover:shadow-xl hover:shadow-green/20 hover:-translate-y-0.5"
      >
        Rejoindre la bêta
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
          <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
      <a
        href="https://github.com/juliensyx/hikingtrack"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 border border-border text-muted px-6 py-3 rounded-xl text-sm hover:border-green/40 hover:text-text transition-all"
      >
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/>
        </svg>
        Voir sur GitHub
      </a>
    </div>

    <!-- App screenshot -->
    <div class="reveal delay-400 relative max-w-5xl mx-auto">
      <!-- Glow beneath the screenshot -->
      <div class="absolute -inset-4 rounded-2xl pointer-events-none"
        style="background: radial-gradient(ellipse at 50% 100%, rgba(74,222,128,0.15) 0%, transparent 70%);">
      </div>

      <!-- Screenshot container -->
      <div class="relative rounded-2xl overflow-hidden border border-border/80 shadow-2xl"
        style="transform: perspective(1200px) rotateX(4deg); box-shadow: 0 40px 120px rgba(0,0,0,0.8), 0 0 0 1px rgba(74,222,128,0.1);">
        <!-- Simulated app UI if no screenshot exists yet -->
        <div class="w-full bg-surface" style="aspect-ratio: 16/9;">
          <img
            src="/screenshots/app-hero.jpg"
            alt="Interface YahoLink — carte de randonnée avec suivi GPS en temps réel"
            class="w-full h-full object-cover object-top"
            onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';"
          />
          <!-- Placeholder if no image -->
          <div class="absolute inset-0 hidden flex-col items-center justify-center text-muted gap-3">
            <div class="text-5xl font-serif">野歩</div>
            <p class="text-sm font-mono">Ajoutez votre capture d'écran dans <code class="text-green">public/screenshots/app-hero.png</code></p>
          </div>
        </div>

        <!-- Top bar overlay (simulated browser chrome) -->
        <div class="absolute top-0 left-0 right-0 h-8 bg-surface/90 backdrop-blur-sm flex items-center px-4 gap-2 border-b border-border/50">
          <div class="w-3 h-3 rounded-full bg-red-500/60"></div>
          <div class="w-3 h-3 rounded-full bg-yellow-500/60"></div>
          <div class="w-3 h-3 rounded-full bg-green/60"></div>
          <div class="flex-1 mx-4">
            <div class="bg-border/40 rounded px-3 py-0.5 text-xs text-muted font-mono text-center max-w-xs mx-auto">
              app.yaholink.fr
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .elevation-path {
    animation: elevationDraw 3s ease-in-out infinite alternate;
  }

  @keyframes elevationDraw {
    0% { transform: translateX(0); }
    100% { transform: translateX(-20px); }
  }
</style>
