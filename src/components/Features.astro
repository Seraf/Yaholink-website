---
const features = [
  {
    id: "gps",
    label: "01",
    title: "Suivi GPS en temps réel",
    description:
      "Votre position est transmise automatiquement depuis votre téléphone Android, toutes les quelques minutes. La carte se met à jour en direct pour vos proches, où qu'ils soient.",
    details: ["Précision GPS native Android", "Mise à jour automatique", "OpenStreetMap intégré", "Profil d'altitude interactif"],
    visual: "map",
  },
  {
    id: "share",
    label: "02",
    title: "Partagez avec vos proches",
    description:
      "Générez un lien unique que vous envoyez à votre famille. Aucune inscription requise pour eux — ils ouvrent le lien et voient votre position. Simple comme ça.",
    details: ["Lien unique révocable", "Aucun compte pour les spectateurs", "Accès depuis n'importe quel navigateur", "Révocation instantanée"],
    visual: "share",
  },
  {
    id: "elevation",
    label: "03",
    title: "Profil d'élévation et étapes",
    description:
      "Importez votre trace GPX pour afficher le dénivelé et les étapes du parcours. Vos proches voient exactement où vous êtes dans votre aventure.",
    details: ["Import GPX", "Marqueurs d'étapes", "Distance parcourue", "Progression globale"],
    visual: "elevation",
  },
  {
    id: "messages",
    label: "04",
    title: "Messages de soutien",
    description:
      "Votre famille peut vous envoyer des encouragements directement depuis la carte. Vous les recevez lors de la prochaine synchronisation GPS.",
    details: ["Messages bidirectionnels", "Réception lors de la sync", "Historique des messages", "Sans application dédiée pour les proches"],
    visual: "messages",
  },
]
---

<section class="py-24 relative overflow-hidden" id="features">
  <!-- Section label -->
  <div class="max-w-6xl mx-auto px-6 mb-20">
    <p class="reveal text-xs font-mono text-green tracking-[0.3em] uppercase mb-4">Fonctionnalités</p>
    <h2 class="reveal delay-100 text-4xl md:text-5xl font-bold tracking-tight">
      Tout ce dont vous avez<br class="hidden md:block" /> besoin, rien de plus.
    </h2>
  </div>

  <!-- Feature rows -->
  <div class="max-w-6xl mx-auto px-6 space-y-px">
    {features.map((feature, i) => (
      <div class={`reveal delay-${(i % 4 + 1) * 100} grid md:grid-cols-2 gap-px bg-border rounded-2xl overflow-hidden`}>
        <!-- Text side -->
        <div class={`bg-surface p-10 md:p-14 flex flex-col justify-center ${i % 2 === 1 ? 'md:order-2' : ''}`}>
          <div class="text-xs font-mono text-green/40 tracking-widest mb-6">{feature.label}</div>
          <h3 class="text-2xl md:text-3xl font-bold mb-4 text-text">{feature.title}</h3>
          <p class="text-muted leading-relaxed mb-8">{feature.description}</p>
          <ul class="space-y-2">
            {feature.details.map((detail) => (
              <li class="flex items-center gap-3 text-sm text-muted/80">
                <span class="w-1 h-1 bg-green rounded-full flex-shrink-0"></span>
                {detail}
              </li>
            ))}
          </ul>
        </div>

        <!-- Visual side -->
        <div class={`bg-bg min-h-64 md:min-h-80 flex items-center justify-center relative overflow-hidden ${i % 2 === 1 ? 'md:order-1' : ''}`}>
          {feature.visual === 'map' && (
            <div class="absolute inset-0 p-6 flex flex-col">
              <div class="flex-1 relative rounded-xl overflow-hidden border border-border/50">
                <!-- Simulated map -->
                <div class="absolute inset-0 bg-surface">
                  <svg viewBox="0 0 400 250" class="w-full h-full opacity-30" fill="none">
                    <path d="M50,180 C80,160 100,140 140,120 C180,100 200,80 250,60 C290,45 320,70 360,50" stroke="#4ADE80" stroke-width="2.5" stroke-linecap="round"/>
                    <circle cx="140" cy="120" r="5" fill="#4ADE80" opacity="0.6"/>
                    <circle cx="250" cy="60" r="5" fill="#4ADE80" opacity="0.6"/>
                    <circle cx="50" cy="180" r="8" fill="none" stroke="#4ADE80" stroke-width="2"/>
                    <circle cx="360" cy="50" r="8" fill="none" stroke="#4ADE80" stroke-width="2"/>
                    <!-- Grid lines for map look -->
                    {[0,1,2,3,4,5,6,7,8].map((n) => (
                      <>
                        <line x1={n*50} y1="0" x2={n*50} y2="250" stroke="#1E2220" stroke-width="1"/>
                        <line x1="0" y1={n*35} x2="400" y2={n*35} stroke="#1E2220" stroke-width="1"/>
                      </>
                    ))}
                  </svg>
                  <!-- Animated GPS dot -->
                  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2">
                    <div class="relative">
                      <div class="w-4 h-4 bg-green rounded-full"></div>
                      <div class="absolute inset-0 w-4 h-4 bg-green rounded-full animate-ping opacity-40"></div>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          )}

          {feature.visual === 'share' && (
            <div class="p-8 w-full max-w-xs mx-auto">
              <div class="bg-surface rounded-xl border border-border p-5 mb-4">
                <div class="text-xs text-muted font-mono mb-2">Lien de partage</div>
                <div class="flex items-center gap-2 bg-bg rounded-lg px-3 py-2 border border-border/60">
                  <span class="text-xs font-mono text-green truncate">app.yaholink.fr/h/abc123</span>
                  <svg class="flex-shrink-0 text-muted" width="14" height="14" viewBox="0 0 16 16" fill="none">
                    <rect x="2" y="4" width="10" height="11" rx="1.5" stroke="currentColor" stroke-width="1.2"/>
                    <path d="M5 4V3a1 1 0 0 1 1-1h7a1 1 0 0 1 1 1v9a1 1 0 0 1-1 1h-1" stroke="currentColor" stroke-width="1.2"/>
                  </svg>
                </div>
              </div>
              <div class="space-y-2">
                {['Marie', 'Papa', 'Club rando'].map((name) => (
                  <div class="flex items-center gap-3 bg-surface rounded-lg px-4 py-3 border border-border/50">
                    <div class="w-7 h-7 rounded-full bg-green/20 flex items-center justify-center text-xs text-green font-semibold">
                      {name[0]}
                    </div>
                    <span class="text-sm text-text">{name}</span>
                    <span class="ml-auto text-xs text-green">● En ligne</span>
                  </div>
                ))}
              </div>
            </div>
          )}

          {feature.visual === 'elevation' && (
            <div class="p-6 w-full">
              <div class="bg-surface rounded-xl border border-border p-4">
                <div class="text-xs text-muted font-mono mb-3">Profil d'élévation</div>
                <svg viewBox="0 0 300 100" fill="none" class="w-full">
                  <defs>
                    <linearGradient id="elevGrad" x1="0" y1="0" x2="0" y2="1">
                      <stop offset="0%" stop-color="#4ADE80" stop-opacity="0.4"/>
                      <stop offset="100%" stop-color="#4ADE80" stop-opacity="0"/>
                    </linearGradient>
                  </defs>
                  <path d="M0,80 C20,80 30,65 50,55 C70,45 80,60 100,45 C120,30 130,15 160,10 C190,5 200,30 230,40 C260,50 270,35 300,30 L300,100 L0,100 Z" fill="url(#elevGrad)"/>
                  <path d="M0,80 C20,80 30,65 50,55 C70,45 80,60 100,45 C120,30 130,15 160,10 C190,5 200,30 230,40 C260,50 270,35 300,30" stroke="#4ADE80" stroke-width="2" stroke-linecap="round"/>
                  <circle cx="160" cy="10" r="4" fill="#4ADE80"/>
                  <circle cx="50" cy="55" r="3" fill="none" stroke="#4ADE80" stroke-width="1.5"/>
                  <circle cx="230" cy="40" r="3" fill="none" stroke="#4ADE80" stroke-width="1.5"/>
                </svg>
                <div class="flex justify-between text-xs text-muted font-mono mt-2">
                  <span>0 km</span>
                  <span>95 km</span>
                  <span>190 km</span>
                </div>
              </div>
            </div>
          )}

          {feature.visual === 'messages' && (
            <div class="p-6 w-full max-w-xs mx-auto space-y-3">
              <div class="flex gap-3">
                <div class="w-7 h-7 rounded-full bg-green/20 flex-shrink-0 flex items-center justify-center text-xs text-green font-semibold">M</div>
                <div class="bg-surface rounded-2xl rounded-tl-none px-4 py-2.5 border border-border max-w-[80%]">
                  <p class="text-sm text-text">Courage ! On pense à toi 🏔️</p>
                  <p class="text-xs text-muted mt-0.5">Marie · 14h32</p>
                </div>
              </div>
              <div class="flex gap-3">
                <div class="w-7 h-7 rounded-full bg-green/20 flex-shrink-0 flex items-center justify-center text-xs text-green font-semibold">P</div>
                <div class="bg-surface rounded-2xl rounded-tl-none px-4 py-2.5 border border-border max-w-[80%]">
                  <p class="text-sm text-text">Bon courage pour le col ! 💪</p>
                  <p class="text-xs text-muted mt-0.5">Papa · 15h01</p>
                </div>
              </div>
              <div class="flex justify-end">
                <div class="bg-green/10 border border-green/30 rounded-2xl rounded-tr-none px-4 py-2.5 max-w-[80%]">
                  <p class="text-sm text-text">Merci ! Pas facile mais ça va 😊</p>
                  <p class="text-xs text-green/60 mt-0.5">Vous · 15h45</p>
                </div>
              </div>
              <div class="flex items-center gap-2 text-xs text-muted/60 font-mono justify-center pt-1">
                <span class="w-1 h-1 bg-green rounded-full animate-pulse"></span>
                Reçu à la prochaine sync GPS
              </div>
            </div>
          )}
        </div>
      </div>
    ))}
  </div>
</section>
